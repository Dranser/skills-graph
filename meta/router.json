        "neural": {
          "entry": "knowledge/csharp-shared/neural/neural_entry.json",
          "manifest": "knowledge/csharp-shared/neural/neural_manifest.json",
          "skills": [
            "knowledge/csharp-shared/neural/tensor-runtime-architecture.json",
            "knowledge/csharp-shared/neural/architecture.json",
