{
  "version": "1.0",
  "description": "Primary-domain router for Skills Graph.",
  "index_source": "meta/index.json",
  "routing_mode": "single_primary_with_attached_skills",
  "rules": {
    "select_primary_from_entry_and_skills": true,
    "ignore_dependencies_during_primary_selection": true,
    "freeze_primary_after_selection": true,
    "allow_support_attachment_after_primary_selection": true,
    "allow_cross_domain_skills": true,
    "allow_cross_cutting_skills": true,
    "disallow_support_override_primary": true,
    "disallow_cross_cutting_override_primary_without_direct_ownership_match": true,
    "disallow_manifest_as_primary": true,
    "skill_json_is_canonical_instruction_source": true
  },
  "scoring": {
    "strong_signal_weight": 10,
    "weak_signal_weight": 4,
    "use_for_weight": 6,
    "ownership_weight": 8,
    "domain_entry_bonus": 5,
    "manifest_bonus": 0,
    "do_not_use_penalty": 9,
    "conflict_penalty": 12,
    "primary_role_bonus": 6,
    "support_role_penalty": 3,
    "cross_cutting_role_penalty": 2
  },
  "matching": {
    "case_sensitive": false,
    "normalize_hyphen_underscore": true,
    "tokenize_query": true,
    "substring_match": true,
    "exact_phrase_bonus": 3,
    "minimum_primary_score": 8,
    "minimum_attachment_score": 4
  },
  "resolution": {
    "tie_break_order": [
      "higher_strong_signal_count",
      "higher_ownership_match_count",
      "higher_primary_role_priority",
      "higher_total_score",
      "stable_index_order"
    ],
    "fallback_mode": "domain_entry_first",
    "fallback_priority": [
      "entry",
      "primary_skill",
      "support_skill"
    ]
  },
  "role_policy": {
    "primary": {
      "can_be_primary": true,
      "can_be_attached": true
    },
    "support": {
      "can_be_primary": true,
      "default_primary": false,
      "can_be_attached": true
    },
    "cross_cutting": {
      "can_be_primary": true,
      "default_primary": false,
      "can_be_attached": true
    },
    "domain_entry": {
      "can_be_primary": true,
      "can_be_attached": false
    },
    "domain_manifest": {
      "can_be_primary": false,
      "can_be_attached": false
    }
  },
  "attachment_policy": {
    "attach_from_same_domain_first": true,
    "include_hard_dependencies": true,
    "include_optional_dependencies_when_relevant": true,
    "include_contextual_dependencies_when_triggered": true,
    "require_declared_relevance_for_cross_domain": true,
    "prefer_attached_cross_cutting_unless_cross_cutting_has_stronger_ownership_match": true,
    "max_same_domain_attachments": 4,
    "max_cross_domain_attachments": 3,
    "cross_cutting_domains": [
      "framework"
    ]
  },
  "domains": {
    "assembly-analysis": {
      "entry": "knowledge/assembly-analysis/assembly-analysis_entry.json",
      "manifest": "knowledge/assembly-analysis/assembly-analysis_manifest.json",
      "skills": [
        "knowledge/assembly-analysis/assembly-reading.json",
        "knowledge/assembly-analysis/dump-pipeline.json",
        "knowledge/assembly-analysis/metadata-parsing.json",
        "knowledge/assembly-analysis/integration-surface-mapping.json"
      ],
      "default_primary_candidates": [
        "integration-surface-mapping",
        "assembly-reading",
        "dump-pipeline"
      ],
      "default_support_candidates": [
        "metadata-parsing"
      ]
    },
    "data-oriented-pipeline": {
