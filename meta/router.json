            "knowledge/csharp-shared/performance/memory-management.json",
            "knowledge/csharp-shared/performance/scheduler.json",
            "knowledge/csharp-shared/performance/work-budgeting.json",
            "knowledge/csharp-shared/performance/measurement-profiling.json",
