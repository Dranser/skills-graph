  },
  "output_contract": {
    "selected_stack": "string",
    "primary_domain": "string",
    "primary_file": "string",
    "attached_skills": [
      "string"
    ],
    "cross_domain_skills": [
      "string"
    ],
    "matched_signals": [
      "string"
    ],
    "rejected_candidates": [
      {
        "id": "string",
        "reason": "string"
      }
    ],
    "confidence": "number"
  }
}
