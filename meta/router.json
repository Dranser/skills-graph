        },
        "performance": {
          "entry": "knowledge/csharp-shared/performance/performance_entry.json",
          "manifest": "knowledge/csharp-shared/performance/performance_manifest.json",
          "skills": [
            "knowledge/csharp-shared/performance/runtime-performance-architecture.json",
            "knowledge/csharp-shared/performance/cache-optimization.json",
