          "manifest": "knowledge/csharp-shared/data-oriented-pipeline/data-oriented-pipeline_manifest.json",
          "skills": [
            "knowledge/csharp-shared/data-oriented-pipeline/pipeline-architecture.json",
            "knowledge/csharp-shared/data-oriented-pipeline/stage-boundaries.json",
            "knowledge/csharp-shared/data-oriented-pipeline/dataflow-state.json",
            "knowledge/csharp-shared/data-oriented-pipeline/invalidation-propagation.json",
            "knowledge/csharp-shared/data-oriented-pipeline/execution-model.json",
            "knowledge/csharp-shared/data-oriented-pipeline/incremental-recompute.json",
            "knowledge/csharp-shared/data-oriented-pipeline/change-batching.json",
            "knowledge/csharp-shared/data-oriented-pipeline/structural-rerun-policy.json",
            "knowledge/csharp-shared/data-oriented-pipeline/stage-contracts.json"
          ],
          "default_primary_candidates": [
            "pipeline-architecture",
            "execution-model",
            "incremental-recompute",
            "change-batching",
            "structural-rerun-policy",
            "stage-contracts"
          ],
          "default_support_candidates": [
            "stage-boundaries",
            "dataflow-state",
            "invalidation-propagation"
          ]
        },
        "framework": {
          "entry": "knowledge/csharp-shared/framework/framework_entry.json",
          "manifest": "knowledge/csharp-shared/framework/framework_manifest.json",
          "skills": [
            "knowledge/csharp-shared/framework/bootstrap.json",
